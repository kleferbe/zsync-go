# Local replication target.
target:
  # ZFS dataset path under which replicated datasets are created.
  dataset: backup/replicas

# Replication source settings.
source:
  # SSH connection to the source host.
  # Leave host empty for local-only replication (no SSH).
  ssh:
    host: root@pve1
    port: 22
  # The source Datasets. Only these will be processed (when tagged subvols exist)
  datasets: 
    - tank
  # ZFS user property on the source that marks datasets for replication.
  # Possible values on source datasets: "all", "subvols", "exclude".
  tag: bashclub:zsync

# Snapshot name patterns eligible for replication and retention policy.
# Only snapshots whose name contains the filter string are considered.
# min_keep: minimum number of snapshots to retain per interval on the target.
snapshot_filter:
  - filter: hourly
    min_keep: 3
  - filter: daily
    min_keep: 3
  - filter: weekly
    min_keep: 3
  - filter: monthly
    min_keep: 1

# Optional checkzfs monitoring integration (for Checkmk).
checkzfs:
  enabled: true
  local: false
  prefix: zsync
  max_age: "1500,6000"
  max_snapshot_count: "150,165"
  spool: local          # "local" or "source"
  spool_max_age: 87000
